    {
      "id": "lLgMYMF1PUFxc2clxAh-Q",
      "type": "text",
      "x": 474.45820319025006,
      "y": 633.5971221261027,
      "width": 1356.0333251953125,
      "height": 300,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 2,
      "strokeStyle": "solid",
      "roughness": 1,
      "opacity": 100,
      "groupIds": [],
