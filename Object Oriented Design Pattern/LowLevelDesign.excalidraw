    {
      "id": "A9qGuPyYF2A74ZhWIZixb",
      "type": "text",
      "x": 557.0317033547656,
      "y": 4105.817334251674,
      "width": 1534.066650390625,
      "height": 395.15772572672233,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
