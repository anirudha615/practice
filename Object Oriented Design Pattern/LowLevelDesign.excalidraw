      "versionNonce": 1918946435,
      "isDeleted": false,
      "boundElements": [],
      "updated": 1742571520550,
      "link": null,
      "locked": false,
      "text": "\n\n4. Template Pattern - \n    a. Here all the classes extend the same interface but the interface holds the algorithm to execute the APIs in order\n       which cannot be changed by the concrete classes.\n    b. It is very different from C++ templates. \n",
      "fontSize": 24.317398506259835,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "\n\n4. Template Pattern - \n    a. Here all the classes extend the same interface but the interface holds the algorithm to execute the APIs in order\n       which cannot be changed by the concrete classes.\n    b. It is very different from C++ templates. \n",
      "autoResize": true,
      "lineHeight": 1.25
    },
