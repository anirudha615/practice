    {
      "id": "8bNiOdW0pEY8KeunpsUup",
      "type": "text",
      "x": 572.7810637396036,
      "y": 7017.572754052948,
      "width": 1340.0333251953125,
      "height": 364.7609775938975,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
