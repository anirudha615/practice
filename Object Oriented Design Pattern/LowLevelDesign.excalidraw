      "fontFamily": 5,
      "textAlign": "center",
      "verticalAlign": "middle",
      "containerId": "JObPBQoaHwVa7GmX-jIPC",
      "originalText": "OfficeBarista\n\ncached_coffee\nconstructor(coffee c)\nm_coffee = c\n\nprepareDripCoffee()\nif !cached_coffee\nreturn m_coffee.prepareDripCoffee\nelse\nreturn cached_coffee\n \n",
      "autoResize": true,
      "lineHeight": 1.25
