      "link": null,
      "locked": false,
      "text": "OfficeBarista\n\ncached_coffee\nconstructor(coffee c)\nm_coffee = new StarbucksBarista()\n\nprepareDripCoffee()\nif !cached_coffee\nreturn m_coffee.prepareDripCoffee\nelse\nreturn cached_coffee\n \n",
      "fontSize": 20,
      "fontFamily": 5,
      "textAlign": "center",
      "verticalAlign": "middle",
