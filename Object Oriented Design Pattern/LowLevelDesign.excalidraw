      "boundElements": [],
      "updated": 1742357225581,
      "link": null,
      "locked": false,
      "text": "Client\n\nCoffee actual =\nStarbucksBarista()\n\nCoffee proxy =\nOfficeBarista(actual)\n\nproxy.prepareDripCoffee()\n// if its already cached,\nit will not make a call to\nStarbucksBarista\nelse if cached it will just\nreturn without making a\ncall to StarbucksBarista",
      "fontSize": 20,
      "fontFamily": 5,
      "textAlign": "center",
      "verticalAlign": "middle",
      "containerId": "cdspKX5vsUq7LezIA-5-F",
      "originalText": "Client\n\nCoffee actual = StarbucksBarista()\n\nCoffee proxy = OfficeBarista(actual)\n\nproxy.prepareDripCoffee()\n// if its already cached, it will not make a call to StarbucksBarista\nelse if cached it will just return without making a call to StarbucksBarista",
      "autoResize": true,
      "lineHeight": 1.25
    },
