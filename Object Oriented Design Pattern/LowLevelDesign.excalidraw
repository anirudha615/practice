    {
      "id": "dK03sKQ323jhkEqrNoM0m",
      "type": "text",
      "x": 661.3431336817227,
      "y": 5405.8431450789,
      "width": 238.86666870117188,
      "height": 500,
      "angle": 0,
      "strokeColor": "#1e1e1e",
