      "versionNonce": 261212458,
      "isDeleted": false,
      "boundElements": [],
      "updated": 1742357225581,
      "link": null,
      "locked": false,
      "text": "Client\n\nCoffee c = Expresso()\nc.printCoffeeFlavor() \n// Expresso\n\nCoffee a = AlmondMilk(c)\nc.printCoffeeFlavor()\n// Almond Milk Expresso\n\nCoffee b = HazelNut\nSyrup(a)\nb.printCoffeeFlavor()\n// Hazelnut Almond Milk\nExpresso\n\nb= HazelNut Syrup(c)\nb.printCoffeeFlavor()\n// Hazelnut Expresso\n",
      "fontSize": 20,
      "fontFamily": 5,
      "textAlign": "center",
      "verticalAlign": "middle",
      "containerId": "quCwt3tgBYpnSFPbqeBuv",
      "originalText": "Client\n\nCoffee c = Expresso()\nc.printCoffeeFlavor() \n// Expresso\n\nCoffee a = AlmondMilk(c)\nc.printCoffeeFlavor()\n// Almond Milk Expresso\n\nCoffee b = HazelNut Syrup(a)\nb.printCoffeeFlavor()\n// Hazelnut Almond Milk Expresso\n\nb= HazelNut Syrup(c)\nb.printCoffeeFlavor()\n// Hazelnut Expresso\n",
      "autoResize": true,
      "lineHeight": 1.25
    },
