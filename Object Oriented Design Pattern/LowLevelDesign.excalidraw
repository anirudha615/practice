      "seed": 2139900138,
      "version": 267,
      "versionNonce": 649821622,
      "isDeleted": false,
      "boundElements": [],
      "updated": 1742425308563,
      "link": null,
      "locked": false,
      "text": "Client\n\nList<CoffeeCommand>\nlistCoffeeCommand\n\nlistCoffeeCommand.add(new\nOrderCoffeeCommand())\n\nlistCoffeeCommand.add(new\nPrepareCoffeeCommand())\n\nlistCoffeeCommand.add(new\nDeliverCoffeeCommand())\n\nloop through listCoffeeCommand and\ncall execute API",
      "fontSize": 20,
      "fontFamily": 5,
      "textAlign": "center",
      "verticalAlign": "middle",
      "containerId": "Chs4dEsMQXwNAIXk6YxUM",
      "originalText": "Client\n\nList<CoffeeCommand> listCoffeeCommand\n\nlistCoffeeCommand.add(new OrderCoffeeCommand())\n\nlistCoffeeCommand.add(new PrepareCoffeeCommand())\n\nlistCoffeeCommand.add(new DeliverCoffeeCommand())\n\nloop through listCoffeeCommand and call execute API",
      "autoResize": true,
      "lineHeight": 1.25
    },
