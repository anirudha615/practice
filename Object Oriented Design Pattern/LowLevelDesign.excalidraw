    {
      "id": "cl-535dYEpxb_gYnQKxbU",
      "type": "text",
      "x": 544.4899968720258,
      "y": 5076.1831857137,
      "width": 1413.5333251953125,
      "height": 243.17398506259835,
      "angle": 0,
