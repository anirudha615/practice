    {
      "id": "zdkb-z1e1GO3q2CPxujwM",
      "type": "text",
      "x": 557.1118871428803,
      "y": 9706.034310594918,
      "width": 354.1000061035156,
      "height": 400,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "#ffffff",
      "fillStyle": "solid",
      "strokeWidth": 2,
      "strokeStyle": "solid",
      "roughness": 1,
      "opacity": 100,
      "groupIds": [],
      "frameId": null,
      "index": "b4i",
