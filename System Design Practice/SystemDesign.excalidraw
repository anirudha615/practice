    {
      "id": "QapMYOzvUj5a3j2UJVaZg",
      "type": "text",
      "x": 3433.5853238952486,
      "y": 182.84326985226835,
      "width": 2837.199951171875,
      "height": 5895,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 4,
      "strokeStyle": "solid",
      "roughness": 1,
      "opacity": 100,
      "groupIds": [],
      "frameId": null,
      "index": "b0C",
