  "elements": [
    {
      "id": "78LQVSAMi1TY9EzRUkzO7",
      "type": "text",
      "x": -245.4583431060007,
      "y": -2134.4490116039624,
      "width": 2992.39990234375,
      "height": 3645,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 2,
      "strokeStyle": "solid",
      "roughness": 1,
      "opacity": 100,
      "groupIds": [],
      "frameId": null,
      "index": "b2U",
