    {
      "id": "OiFzRcJZmEdAtjOuelhdN",
      "type": "text",
      "x": 1327.2052376030324,
      "y": 2010.9254564743637,
      "width": 390.3333435058594,
      "height": 25,
      "angle": 0,
      "strokeColor": "#1e1e1e",
