  "elements": [
    {
      "id": "uwYTWo2pMZM-Z_VtOyRaU",
      "type": "text",
      "x": 346.8388982943559,
      "y": -422.3280312247207,
      "width": 1844.199951171875,
      "height": 1350,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 2,
      "strokeStyle": "solid",
      "roughness": 1,
      "opacity": 100,
      "groupIds": [],
      "frameId": null,
      "index": "b4R",
