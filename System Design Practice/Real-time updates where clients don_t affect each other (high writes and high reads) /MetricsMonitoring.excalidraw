  "elements": [
    {
      "id": "UcRYKQPtfYEHau_MtLCGf",
      "type": "text",
      "x": 35.73943353549555,
      "y": -2848.472107927071,
      "width": 2939.166748046875,
      "height": 3735,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 2,
      "strokeStyle": "solid",
