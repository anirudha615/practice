    {
      "id": "KBRtaQjTQcoqh0NBUh-JS",
      "type": "text",
      "x": 7195.762646377406,
      "y": 7436.4910470390005,
      "width": 2378.10009765625,
      "height": 3960,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 4,
      "strokeStyle": "solid",
      "roughness": 1,
      "opacity": 100,
      "groupIds": [],
      "frameId": null,
      "index": "b0Q",
      "roundness": null,
      "seed": 450332744,
      "version": 1719,
