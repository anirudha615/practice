    {
      "id": "xyjJojyI33XpcJW3U0t5n",
      "type": "text",
      "x": 629.7938361778122,
      "y": -2050.3113120629982,
      "width": 1661.433349609375,
      "height": 3425,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 2,
      "strokeStyle": "solid",
