    {
      "id": "AVMmZmrrUihokoxFQbXzf",
      "type": "text",
      "x": 223.3548063625684,
      "y": -2730.0251756494454,
      "width": 1966.5999755859375,
      "height": 4500,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 2,
      "strokeStyle": "solid",
      "roughness": 1,
      "opacity": 100,
      "groupIds": [],
      "frameId": null,
      "index": "b21",
      "roundness": null,
      "seed": 1520121209,
      "version": 18170,
