    {
      "id": "6y0xDbtofqTsL0abY_aUY",
      "type": "text",
      "x": 591.0697696018052,
      "y": -1581.1311086586613,
      "width": 1537.433349609375,
      "height": 3275,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 2,
      "strokeStyle": "solid",
      "roughness": 1,
      "opacity": 100,
      "groupIds": [],
      "frameId": null,
      "index": "b20",
