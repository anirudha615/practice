    {
      "id": "vuJProk_5LfDgP98jdFRH",
      "type": "text",
      "x": 1234.648125973639,
      "y": 1655.2541066690267,
      "width": 425.8999938964844,
      "height": 75,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 2,
      "strokeStyle": "solid",
      "roughness": 0,
      "opacity": 100,
      "groupIds": [],
