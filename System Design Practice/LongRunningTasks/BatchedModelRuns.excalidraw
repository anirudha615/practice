    {
      "id": "2qEz8GyJkFgVuCSC0sGPK",
      "type": "text",
      "x": 788.1005503388218,
      "y": -2496.849428595181,
      "width": 1525.86669921875,
      "height": 3800,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 2,
      "strokeStyle": "solid",
      "roughness": 1,
      "opacity": 100,
      "groupIds": [],
      "frameId": null,
      "index": "b3J",
      "roundness": null,
      "seed": 33310503,
      "version": 12959,
