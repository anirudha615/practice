    {
      "id": "2qEz8GyJkFgVuCSC0sGPK",
      "type": "text",
      "x": 788.1005503388218,
      "y": -2496.849428595181,
      "width": 1525.86669921875,
      "height": 3800,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
