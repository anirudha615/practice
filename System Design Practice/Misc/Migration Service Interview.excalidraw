    {
      "id": "wUzQ278unS1ZuyKtqUGZL",
      "type": "text",
      "x": 458,
      "y": 1380,
      "width": 52.400001525878906,
      "height": 25,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 2,
      "strokeStyle": "solid",
