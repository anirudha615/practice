      "isDeleted": false,
      "boundElements": [],
      "updated": 1739637169593,
      "link": null,
      "locked": false,
      "text": "K1/V1",
      "fontSize": 20,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "K1/V1",
      "autoResize": true,
      "lineHeight": 1.25
    },
    {
      "id": "5HWP0GvUBhJshXCtrW9Ys",
      "type": "text",
      "x": 55,
      "y": 1801,
      "width": 1047.933349609375,
      "height": 225,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 2,
      "strokeStyle": "solid",
      "roughness": 1,
      "opacity": 100,
      "groupIds": [],
      "frameId": null,
      "index": "b01",
      "roundness": null,
      "seed": 874760381,
      "version": 901,
      "versionNonce": 1243477231,
      "isDeleted": false,
      "boundElements": [],
      "updated": 1739637169593,
      "link": null,
      "locked": false,
      "text": "1. Commit to WAL1 and receive an ack\n2. Commit to Journal Service and receive an ack\n3. Passing the entry to Node2 via existing mechanism/old architecture\n4. Node 2 receives the log entry from existing mechanism and Journal Service\n5. We will collect metrics to gain confidence on whether the data \nreceived by new and existing architecture is similar\n6. Once received confidence, we will try remove the replication/existing mechanism between nodes 1, 2 and 3\n\n",
      "fontSize": 20,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "1. Commit to WAL1 and receive an ack\n2. Commit to Journal Service and receive an ack\n3. Passing the entry to Node2 via existing mechanism/old architecture\n4. Node 2 receives the log entry from existing mechanism and Journal Service\n5. We will collect metrics to gain confidence on whether the data \nreceived by new and existing architecture is similar\n6. Once received confidence, we will try remove the replication/existing mechanism between nodes 1, 2 and 3\n\n",
      "autoResize": true,
      "lineHeight": 1.25
    },
    {
      "id": "e9WCoRRh6fDK3njLfl6Yj",
